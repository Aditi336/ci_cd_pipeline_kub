1. install jenkins in docker(if open-jdk is not installed)
    # mkdir -p ~/jenkins_home
    
    # docker run -d \ --name jenkins \ -p 8080:8080 \  -p 50000:50000 \ -v ~/jenkins_home:/var/jenkins_home \ -v /var/run/docker.sock:/var/run/docker.sock \ jenkins/jenkins:lts

    # docker exec jenkins cat /var/jenkins_home/secrets/initialAdminPassword = this is used to get the jenkins passwd which is used to install requried packages
    # http://localhost:8080 = open the link and add the admin passwd and install the required packages
