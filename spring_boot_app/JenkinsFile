pipeline{
    agent {
        docker {
        image 'docker:latest'
        args '-v /var/run/docker.sock:/var/run/docker.sock'
    }
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Docker image tag (leave empty to use build number)')
    }

    environment{
        IMAGE = "amulu874/index-html:${params.IMAGE_TAG ?: BUILD_NUMBER}"
    }
    stages{
        stage('checkout'){
            steps{
                git 'https://github.com/Aditi336/ci_cd_pipeline_kub.git'
            }
        }
        stage('docker build'){
            steps{
                sh ' docker build -t $IMAGE "./spring_boot_app"'
            }
        }
        stage('docker push'){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub', 
                    usernameVariable:'USER',
                    passwordVariable:'PASS'
                    )]) {
                

                sh ''' 
                echo $PASS | docker login -u $USER --password-stdin
                docker push $IMAGE'''
                    }
            }
        }
        
        stage('update manifest repo'){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'github_clone',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                    )]){
                    sh '''
                    rm -rf cd_k8s_manifest
                    git clone https://Aditi336:${GIT_TOKEN}@github.com/Aditi336/cd_k8s_manifest.git
                    cd cd_k8s_manifest
                    sed -i "s|amulu876/index-html:.*|amulu876/index-html:${BUILD_NUMBER}|g" cicd-deployment.yaml

                    git config user.email "aditijuly2004@gmail.com"
                    git config user.name "jenkins"

                    git add cicd-deployment.yaml
                    git diff --cached --quiet || git commit -m "Update image to ${BUILD_NUMBER}"
                    git push origin main

                    '''
                }
            }
        }
        // stage('k8s deploy'){
        //     steps{
        //         sh '''
        //         kubectl get pods
        //         kubectl set image deployment/cicd-deployment \
        //        cicd-deployment=$IMAGE
        //         '''
        //     }
        // }
    }
}